{
  "name": "pnplabs-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "updates:generate": "node tools/generate-milestone-updates.mjs",
    "updates:check": "node tools/generate-milestone-updates.mjs --check",
    "verify:seal": "node tools/verify-release-seal.mjs",
    "deployment:generate": "node tools/deployment-provenance.mjs",
    "deployment:check": "node tools/deployment-provenance.mjs --check",
    "verify:production": "node tools/check-production-deployment.mjs",
    "examples:minimal": "node tools/run-minimal-examples.mjs",
    "pnp:import-run": "node tools/import-pnp-verifier-run.mjs",
    "pnp:normalize-run": "node tools/normalize-pnp-verifier-run.mjs",
    "pnp:compare-runs": "node tools/compare-pnp-verifier-runs.mjs",
    "pnp:run-matrix": "node tools/generate-pnp-verifier-run-matrix.mjs",
    "pnp:run-summary": "node tools/generate-pnp-verifier-run-summary.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:negative": "node --test tests/negative/*.test.mjs",
    "test:audit-targets": "node --test tests/audit-targets/*.test.mjs && node tools/check-cross-repo-targets.mjs",
    "test:docs": "node tools/check-doc-links.mjs",
    "repro:smoke": "npm run verify:seal && npm run examples:minimal",
    "test": "npm run updates:check && npm run test:unit && npm run verify:seal && npm run examples:minimal && npm run test:negative && npm run repro:smoke && npm run test:docs"
  },
  "engines": {
    "node": ">=20"
  }
}
